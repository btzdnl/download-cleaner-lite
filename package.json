{
  "name": "download-cleaner-lite",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "tsc",
    "pack": "rm -f download-cleaner-lite.zip && cat files_to_zip.txt | zip -@ download-cleaner-lite.zip",
    "lint": "eslint lib/*.ts *.ts",
    "lint:format": "prettier --check *.ts lib/*.ts *.html *.json",
    "format": "prettier --write *.ts lib/*.ts *.html *.json"
  },
  "devDependencies": {
    "@eslint/js": "~9.39.1",
    "eslint": "~9.39.1",
    "globals": "^16.5.0",
    "prettier": "3.2.4",
    "typescript": "~5.9.3",
    "typescript-eslint": "~8.46.4",
    "web-ext-types": "~3.2.1"
  },
  "prettier": {
    "trailingComma": "es5",
    "tabWidth": 2,
    "semi": true,
    "singleQuote": false
  }
}
